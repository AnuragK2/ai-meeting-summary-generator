# =============================================================================
# meet.ai backend — environment variables
# Copy this file to `.env` and fill in OPENAI_API_KEY at minimum.
# =============================================================================

# ----- OpenAI (required) -----
# Get a key at https://platform.openai.com/api-keys.
# The server refuses to start without this and exits with a clear message.
OPENAI_API_KEY=

# Any chat model that supports the strict json_schema response format.
# `gpt-4o-mini` is the default — cheap, fast, accurate enough for transcripts
# up to ~hour-long meetings. Swap for `gpt-4o` if you need higher quality.
OPENAI_MODEL=gpt-4o-mini

# Hard per-request timeout in milliseconds for the OpenAI call.
# Includes the strict JSON parse step but not the corrective retry.
OPENAI_TIMEOUT_MS=45000

# ----- HTTP server -----
PORT=8000

# Comma-separated list of origins allowed by CORS. Use `*` to allow any
# origin (dev only). Defaults to the Vite dev server on port 3000.
ALLOWED_ORIGINS=http://localhost:3000

# Per-IP rate limit for the two LLM-hitting endpoints (POST /api/meetings
# and POST /api/meetings/:id/regenerate). Other endpoints are unlimited.
EXTRACTION_RATE_LIMIT_PER_MIN=10

# ----- Storage -----
# Anything except `:memory:` is persisted to disk. Parent directory is
# created automatically.
DB_PATH=./data/app.db
